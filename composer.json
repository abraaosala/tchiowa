{
    "name": "salaab/framework",
    "description": "Um mini-framework em PHP prático, leve e moderno, construído utilizando os poderosos e flexíveis componentes do Eloquent (Illuminate) e Symfony Console. Esta base funciona como um esqueleto (boilerplate) pronto para o ínicio de qualquer projeto PHP com uma estrutura organizada (MVC/CSR)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "dompdf/dompdf": "^3.1",
        "eftec/bladeone": "^4.9",
        "filp/whoops": "^2.18",
        "illuminate/config": "^10.49",
        "illuminate/container": "^10.0",
        "illuminate/database": "^10.0",
        "illuminate/events": "^10.0",
        "illuminate/filesystem": "^10.0",
        "illuminate/http": "^10.49",
        "illuminate/pagination": "^10.49",
        "illuminate/routing": "^10.0",
        "illuminate/validation": "^10.0",
        "illuminate/view": "^10.0",
        "nyholm/psr7": "^1.8",
        "robmorgan/phinx": "^0.13.0",
        "symfony/console": "^6.4",
        "symfony/psr-http-message-bridge": "^7.4",
        "symfony/var-dumper": "^7.4",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "pestphp/pest": "^2.0",
        "fakerphp/faker": "^1.21"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Helpers/helpers.php"
        ]
    },
    "authors": [
        {
            "name": "Abraão Xavier Sungo Sala",
            "email": "abraao.sala@nsimbaengenharia.com"
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
