#!/usr/bin/env php
<?php

declare(strict_types=1);

error_reporting(E_ALL & ~E_DEPRECATED & ~E_USER_DEPRECATED);

require __DIR__ . '/vendor/autoload.php';

use Dotenv\Dotenv;
use Illuminate\Container\Container;
use Illuminate\Database\Capsule\Manager as Capsule;
use Illuminate\Config\Repository as ConfigRepository;
use Symfony\Component\Console\Application;

// Carrega variáveis de ambiente
if (file_exists(__DIR__ . '/.env')) {
    Dotenv::createImmutable(__DIR__)->load();
}

if (!function_exists('env')) {
    function env(string $key, mixed $default = null): mixed {
        $value = $_ENV[$key] ?? $_SERVER[$key] ?? null;
        return $value === null ? $default : $value;
    }
}

// Inicializa Container
$container = new Container();
Container::setInstance($container);

// Config
$configPath = __DIR__ . '/config';
$configFiles = glob($configPath . '/*.php') ?: [];
$configData = [];
foreach ($configFiles as $file) {
    $name = basename($file, '.php');
    $configData[$name] = require $file;
}
$config = new ConfigRepository($configData);
$container->instance('config', $config);

// Database / Eloquent
$capsule = new Capsule($container);
$defaultConnection = $config->get('database.default') ?: env('DB_CONNECTION', 'mysql');
$dbConfig = $config->get("database.connections.{$defaultConnection}");

if (empty($dbConfig) && $defaultConnection !== 'mysql') {
    $defaultConnection = 'mysql';
    $dbConfig = $config->get("database.connections.mysql");
}

if (!empty($dbConfig)) {
    $capsule->addConnection($dbConfig);
    $capsule->setAsGlobal();
    $capsule->bootEloquent();
}

$application = new Application('Tchiowa Console', '1.0.0');

// Serviços partilhados
$dbManager = new \App\Console\DatabaseManager();
$phinxRunner = new \App\Console\PhinxRunner();
$stubService = new \App\Console\StubService();

// Comandos sem dependências
$application->add(new \App\Console\Commands\Serve());

// Comandos com DatabaseManager
$application->add(new \App\Console\Commands\DbCreate($dbManager));
$application->add(new \App\Console\Commands\DbDrop($dbManager));

// Comandos com PhinxRunner
$application->add(new \App\Console\Commands\DbSeed($phinxRunner));
$application->add(new \App\Console\Commands\MigrateRollback($phinxRunner));
$application->add(new \App\Console\Commands\MigrateStatus($phinxRunner));
$application->add(new \App\Console\Commands\MigrateBreakpoint($phinxRunner));
$application->add(new \App\Console\Commands\MakeMigration($phinxRunner));
$application->add(new \App\Console\Commands\MakeSeed($phinxRunner));

// Comandos com StubService
$application->add(new \App\Console\Commands\MakeController($stubService));
$application->add(new \App\Console\Commands\MakeModel($stubService));
$application->add(new \App\Console\Commands\MakeService($stubService));
$application->add(new \App\Console\Commands\MakeMiddleware($stubService));
$application->add(new \App\Console\Commands\MakeRepository($stubService));

// Comandos com dependências múltiplas
$application->add(new \App\Console\Commands\Migrate($dbManager, $phinxRunner));

$application->run();
